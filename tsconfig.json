{
  "compilerOptions": {
    "target": "es2017",
    "lib": [
      "es2017"
    ],
    "strict": true,
    "typeRoots": [
      "./node_modules/@types",
      "./node_modules/@figma"
    ],
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "jsx": "preserve",
    "noEmit": true
  },
  "include": ["src/**/*"]
}